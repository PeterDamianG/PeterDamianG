{
  "name": "@peterdg/peterdg-personalweb",
  "version": "0.3.0",
  "description": "Una Web Personal, para el desarrollador Peter Damián Gómez",
  "keywords": [
    "vite",
    "preact",
    "web",
    "personal",
    "portfolio",
    "github-pages",
    "typescript"
  ],
  "author": "Peter Damián Gómez <PeterDamianG@Gmail.com> (https://github.com/PeterDamianG)",
  "homepage": "https://peterdg.com.ar/",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prettier": "prettier --ignore-path .gitignore --write \"src/**/*.{js,jsx,css,ts,tsx}\" && prettier --check \"src/**/*.{js,jsx,css,ts,tsx}\"",
    "lint": "eslint src",
    "test": "vitest run --reporter=verbose",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "2.9.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-istanbul": "3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterDamianG/PeterDamianG"
  },
  "bugs": {
    "url": "https://github.com/PeterDamianG/PeterDamianG/issues"
  }
