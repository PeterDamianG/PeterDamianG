{
  "name": "@peterdg/peterdg-personalweb",
  "version": "0.3.0",
  "description": "Una Web Personal, para el desarrollador Peter Damián Gómez",
  "keywords": [
    "vite",
    "preact",
    "web",
    "personal",
    "portfolio",
    "github-pages",
    "typescript"
  ],
  "author": "Peter Damián Gómez <PeterDamianG@Gmail.com> (https://github.com/PeterDamianG)",
  "homepage": "https://peterdg.com.ar/",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prettier": "prettier --ignore-path .gitignore --write \"src/**/*.{js,jsx,css,ts,tsx}\" && prettier --check \"src/**/*.{js,jsx,css,ts,tsx}\"",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --reporter=verbose",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.8.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterDamianG/PeterDamianG"
  },
  "bugs": {
    "url": "https://github.com/PeterDamianG/PeterDamianG/issues"
  }
}
